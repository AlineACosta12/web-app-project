extends layout

block content
  style.
    .hero { text-align: center; padding: 4rem 1rem 3rem; }
    .hero h2 { font-size: 2.5rem; margin-bottom: 0.75rem; }
    .hero h2 span { color: #06b6d4; }
    .hero p { color: #c9cad4; font-size: 1.05rem; margin-bottom: 2rem; }
    .mood-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; max-width: 700px; margin: 0 auto; }
    .mood-link { display: block; padding: 1.5rem; border-radius: 12px; text-align: center; font-weight: bold; color: #000; font-size: 1rem; transition: opacity 0.2s; }
    .mood-link:hover { opacity: 0.85; text-decoration: none; }
    @media (max-width: 600px) { .mood-grid { grid-template-columns: repeat(2, 1fr); } }

  div.hero
    h2 What&apos;s your #[span mood]?
    p Pick a mood and we&apos;ll find the right movie for you.
    div.mood-grid
      a.mood-link(href='/browse/mood/happy' style='background:#f59e0b') 😄 Happy
      a.mood-link(href='/browse/mood/sad' style='background:#3b82f6') 😢 Sad
      a.mood-link(href='/browse/mood/romantic' style='background:#ec4899') ❤️ Romantic
      a.mood-link(href='/browse/mood/motivated' style='background:#10b981') 💪 Motivated
      a.mood-link(href='/browse/mood/bored' style='background:#c9cad4') 😑 Bored
      a.mood-link(href='/browse/mood/mindblow' style='background:#8b5cf6') 🤯 Mind Blown
