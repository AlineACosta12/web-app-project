extends layout

block content
  style.
    .page-header { margin-bottom: 1.5rem; }
    .page-header h2 { font-size: 1.6rem; text-transform: capitalize; }
    .page-header p { color: #c9cad4; font-size: 0.9rem; margin-top: 0.25rem; }
    .movie-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 1.25rem; }
    .movie-card { background: #1a1b1f; border: 1px solid #2a2b30; border-radius: 10px; overflow: hidden; }
    .movie-card img { width: 100%; display: block; }
    .movie-card .info { padding: 0.75rem; }
    .movie-card .info h3 { font-size: 0.85rem; margin-bottom: 0.25rem; line-height: 1.3; }
    .movie-card .info span { font-size: 0.75rem; color: #c9cad4; }
    .no-poster { height: 220px; background: #2a2b30; display: flex; align-items: center; justify-content: center; color: #c9cad4; font-size: 0.8rem; }
    .back-link { display: inline-block; margin-bottom: 1.5rem; color: #06b6d4; font-size: 0.9rem; }

  a.back-link(href='/') ← Back to moods

  div.page-header
    h2 #{mood} movies
    p Showing #{movies.length} results

  div.movie-grid
    each movie in movies
      div.movie-card
        if movie.poster_path
          img(
            src='https://image.tmdb.org/t/p/w500' + movie.poster_path
            alt=movie.title
            loading='lazy'
          )
        else
          div.no-poster No image
        div.info
          h3= movie.title
          span ⭐ #{movie.vote_average ? movie.vote_average.toFixed(1) : 'N/A'}
